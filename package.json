{
  "name": "disbox-linux",
  "version": "4.9.5",
  "description": "Disbox by naufal-backup - Discord Cloud Storage - High Performance with Multi-Account & App Lock",
  "author": {
    "name": "naufal-backup",
    "email": "alamsyahnaufal453@gmail.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "setup": "npm install"
  },
  "build": {
    "appId": "com.disbox.linux",
    "productName": "Disbox",
    "copyright": "Copyright © 2024 naufal-backup",
    "publish": [
      {
        "provider": "github",
        "owner": "naufal-backup",
        "repo": "disbox-linux"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "electron/icon.png",
      "artifactName": "Disbox-Windows.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Disbox",
      "artifactName": "Disbox-Windows-Setup.${ext}"
    },
    "portable": {
      "artifactName": "Disbox-Windows-Portable.${ext}"
    },
    "pacman": {
      "artifactName": "${productName}-Linux-x64.pacman"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "maintainer": "naufal-backup <alamsyahnaufal453@gmail.com>",
      "category": "Network",
      "icon": "electron/icons",
      "executableName": "disbox",
      "artifactName": "${productName}-Linux-x64.${ext}",
      "desktop": {
        "Name": "Disbox",
        "Comment": "Discord-based cloud storage with AES-GCM encryption",
        "Categories": "Network;FileTransfer;",
        "StartupWMClass": "disbox",
        "GenericName": "Cloud Storage Client",
        "Icon": "disbox"
      }
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/syne": "^5.2.7",
    "@tanstack/react-query": "^5.96.1",
    "archiver": "^7.0.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-inner-image-zoom": "^4.0.1",
    "react-router-dom": "^6.22.2",
    "react-syntax-highlighter": "^16.1.1"
  }
}
